# ── Site ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://thursdai.com

# ── PostHog analytics + feature flags ─────────────────────────────────────────
# Get from posthog.com → Project Settings → API Keys
NEXT_PUBLIC_POSTHOG_KEY=phc_XXXX
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
# Server-side key for hero A/B test flag evaluation (never expose to browser)
POSTHOG_PERSONAL_API_KEY=phx_XXXX

# ── HubSpot (demo request form) ────────────────────────────────────────────────
# Settings → Integrations → API Key
HUBSPOT_PORTAL_ID=
HUBSPOT_FORM_ID=
# Private app token (scopes: forms, contacts)
HUBSPOT_ACCESS_TOKEN=

# ── Sentry error tracking ──────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ── Security pack delivery (optional — used by /api/security-pack) ────────────
# Resend (or SendGrid) for emailing the security pack ZIP
RESEND_API_KEY=
SECURITY_PACK_FROM_EMAIL=security@thursdai.com

# ── Vercel deployment ──────────────────────────────────────────────────────────
# Set in GitHub repo secrets (never in .env files)
# VERCEL_TOKEN=
# VERCEL_ORG_ID=
# VERCEL_PROJECT_ID=

# ── Lighthouse CI ─────────────────────────────────────────────────────────────
# Set in GitHub repo secrets
# LHCI_GITHUB_APP_TOKEN=
